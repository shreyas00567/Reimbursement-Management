<odoo>

<!-- Expense Form View -->

<record id="view_expense_form" model="ir.ui.view">

    <field name="name">expense.claim.form</field>

    <field name="model">expense.claim</field>

    <field name="arch" type="xml">

        <form>

            <sheet>

                <group>

                    <field name="name"/>

                    <field name="employee_id"/>

                    <field name="manager_id"/>

                    <field name="amount"/>

                    <field name="category"/>

                    <field name="date"/>

                    <field name="description"/>

                    <field name="receipt"/>

                    <field name="state"/>

                </group>

                <group>

                    <field name="approval_status"/>

                    <field name="manager_comment"/>

                    <field name="history"/>

                </group>

                <footer>

                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"/>

                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-success"/>

                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"/>

                </footer>

            </sheet>

        </form>

    </field>

</record>


<!-- Expense Tree View -->

<record id="view_expense_tree" model="ir.ui.view">

    <field name="name">expense.claim.tree</field>

    <field name="model">expense.claim</field>

    <field name="arch" type="xml">

        <tree>

            <field name="name"/>

            <field name="employee_id"/>

            <field name="amount"/>

            <field name="category"/>

            <field name="state"/>

        </tree>

    </field>

</record>


<!-- Action -->

<record id="action_expense" model="ir.actions.act_window">

    <field name="name">Expenses</field>

    <field name="res_model">expense.claim</field>

    <field name="view_mode">tree,form</field>

</record>


<!-- Menu -->

<menuitem id="menu_expense_root"

          name="Reimbursement"/>


<menuitem id="menu_expense"

          name="Expenses"

          parent="menu_expense_root"

          action="action_expense"/>


</odoo>